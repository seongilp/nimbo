# Nimbo runtime configuration (read by systemd EnvironmentFile).
# Copy to /etc/nimbo/nimbo.env and edit. Restart after changes:
#   sudo systemctl restart nimbo

# Port the app listens on. Put a reverse proxy (Caddy) in front for HTTPS.
PORT=3000
# Bind address. 127.0.0.1 = only reachable via the reverse proxy (recommended).
# 0.0.0.0 = reachable directly on the LAN (no TLS — use only on trusted nets).
HOSTNAME=127.0.0.1

# Production mode.
NODE_ENV=production

# --- App settings -------------------------------------------------------
# Colon-separated roots the File Station may browse. "/" = whole filesystem
# (fine for a single-admin appliance). Restrict to specific paths if you prefer.
NAS_FILE_ROOTS=/
# Default media/appdata locations for Package Center installs.
NIMBO_APPDATA=/opt/appdata
NIMBO_MEDIA=/srv/media
# Where generated service configs are written (must be root-writable).
RSYNC_CONF=/etc/rsyncd.conf
SMB_CONF=/etc/samba/smb.conf.d/shares.conf
NFS_EXPORTS=/etc/exports.d/nas.exports
SMB_TM_CONF=/etc/samba/smb.conf.d/timemachine.conf
CERT_DIR=/etc/nimbo/certs

# Force real mode (never serve demo/mock data) — set on the real host.
NAS_MOCK=0
